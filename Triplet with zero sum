class Solution {
    public boolean findTriplets(int[] arr) {
        int n=arr.length;
        for(int i=0;i<n;i=i+1){
            for(int j=i+1;j<n;j=j+1){
                for(int k=j+1;k<n;k=k+1){
                    if(arr[i]+arr[j]+arr[k]==0){
                        return true;
                    }
                }
            }
        }
        return false;
    }
}
